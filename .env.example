# External API (existing)
# NEXT_PUBLIC_API_URL=https://your-api.example.com
NEXT_PUBLIC_API_URL=https://rok-m-backend.onrender.com/api

# Error monitor QA (optional; dev pages open in development by default)
# NEXT_PUBLIC_ERROR_MONITOR_TEST=true

# Dev: на всіх сторінках плаваюча кнопка «Dev Monitor» + performance-monitor.js
# (увімкнено автоматично при NODE_ENV=development)
# Dashboard in production (optional secret for GET /api/log-error):
# ERROR_MONITOR_DASHBOARD_KEY=your-secret-key

# Firebase Admin — for /api/log-error → Firestore collection `client_errors`
# If omitted, errors are appended to logs/client-errors.jsonl
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
